        /**
         * ==========================================
         * TAB LAPORAN KEUANGAN DAN MENU TERLARIS (SVG BAR CHART)
         * ==========================================
         */
        function renderAdminFinanceReport(container) {
            const completed = AppState.orderHistory.filter(o => o.status === 'completed');
            
            let totalTransactions = completed.length;
            let grossSales = 0; 
            let taxCollected = 0; 
            let netSales = 0; 

            completed.forEach(order => {
                grossSales += order.total;
                const sub = order.total / (1 + AppState.settings.taxRate);
                netSales += sub;
                taxCollected += (order.total - sub);
            });

            const menuUsage = {};
            completed.forEach(order => {
                order.items.forEach(item => {
                    menuUsage[item.id] = (menuUsage[item.id] || 0) + item.qty;
                });
            });

            const popularMenus = [];
            for (const id in menuUsage) {
                const product = AppState.products.find(x => x.id === id);
                popularMenus.push({
                    name: product ? product.name : `Menu Dihapus (${id})`,
                    qty: menuUsage[id]
                });
            }
            
            popularMenus.sort((a,b) => b.qty - a.qty);
            const top5 = popularMenus.slice(0, 5);
            const maxQty = top5.length > 0 ? top5[0].qty : 1;

            container.innerHTML = `
                <div class="flex justify-between items-center mb-8">
                    <h2 class="text-2xl font-bold text-white flex items-center gap-2"><i class="fas fa-wallet text-neon-blue"></i> Laporan Keuangan POS</h2>
                    <span class="text-xs text-neon-purple font-mono bg-neon-purple/10 border border-neon-purple/30 px-3 py-1 rounded-full"><i class="fas fa-calendar-day mr-1"></i> Hari Ini</span>
                </div>

                <!-- CARDS NERACA KEUANGAN -->
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
                    <div class="glass-panel p-6 rounded-2xl border-l-4 border-neon-blue flex flex-col justify-between shadow-neon-blue">
                        <span class="text-gray-400 text-xs font-semibold uppercase">Total Omset Kotor</span>
                        <p class="text-2xl font-black text-white mt-2">${formatRp(grossSales)}</p>
                        <span class="text-[9px] text-gray-500 mt-1">Termasuk Pajak PB1</span>
                    </div>
                    <div class="glass-panel p-6 rounded-2xl border-l-4 border-neon-green flex flex-col justify-between shadow-[0_0_15px_rgba(57,255,20,0.15)]">
                        <span class="text-gray-400 text-xs font-semibold uppercase">Omset Bersih (Net)</span>
                        <p class="text-2xl font-black text-white mt-2">${formatRp(netSales)}</p>
                        <span class="text-[9px] text-gray-500 mt-1">Pendapatan Bersih Outlet</span>
                    </div>
                    <div class="glass-panel p-6 rounded-2xl border-l-4 border-neon-purple flex flex-col justify-between shadow-neon-purple">
                        <span class="text-gray-400 text-xs font-semibold uppercase">Pajak Terkumpul (PB1)</span>
                        <p class="text-2xl font-black text-white mt-2">${formatRp(taxCollected)}</p>
                        <span class="text-[9px] text-gray-500 mt-1">Pajak PB1 (${AppState.settings.taxRate * 100}%)</span>
                    </div>
                    <div class="glass-panel p-6 rounded-2xl border-l-4 border-yellow-500 flex flex-col justify-between shadow-[0_0_15px_rgba(234,179,8,0.15)]">
                        <span class="text-gray-400 text-xs font-semibold uppercase">Jumlah Transaksi</span>
                        <p class="text-2xl font-black text-white mt-2">${totalTransactions}</p>
                        <span class="text-[9px] text-gray-500 mt-1">Invoice Selesai</span>
                    </div>
                </div>

                <!-- ANALISA GRAFIK MENU TERLARIS -->
                <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
                    <div class="glass-panel p-6 rounded-2xl border border-white/5 lg:col-span-2">
                        <h3 class="text-lg font-bold text-white mb-6 flex items-center gap-2"><i class="fas fa-square-poll-horizontal text-neon-blue"></i> Grafik Top 5 Produk Terlaris</h3>
                        
                        ${top5.length === 0 ? `
                            <div class="p-12 text-center text-gray-500 font-mono text-xs">
                                Belum ada data transaksi untuk membentuk grafik analitik.
                            </div>
                        ` : `
                            <div class="space-y-6">
                                ${top5.map(item => {
                                    const percent = (item.qty / maxQty) * 100;
                                    return `
                                        <div>
                                            <div class="flex justify-between text-xs mb-1">
                                                <span class="text-white font-medium">${item.name}</span>
                                                <span class="text-neon-blue font-mono font-bold">${item.qty} Terjual</span>
                                            </div>
                                            <div class="w-full h-3 bg-coffee-900 rounded-full overflow-hidden border border-white/5">
                                                <div class="h-full bg-gradient-to-r from-neon-blue to-neon-purple rounded-full shadow-[0_0_10px_rgba(0,240,255,0.4)]" style="width: ${percent}%"></div>
