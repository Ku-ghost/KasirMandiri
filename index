        async function sendToDiscord(channel, payload) {
            const url = channel === 'kitchen' ? AppState.settings.webhookKitchen : AppState.settings.webhookCashier;
            if (!url) return;
            try {
                await fetch(url, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) });
            } catch (error) { console.error(`Webhook Error:`, error); }
        }

        async function processOrderSubmission(customerEmail) {
            if (AppState.cart.length === 0) return;

            const timeNow = new Date().toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit' });
            let kitchenItems = ''; let cashierItems = ''; let subtotal = 0;

            AppState.cart.forEach(item => {
                const product = AppState.products.find(p => p.id === item.id);
                if (product) {
                    subtotal += product.price * item.qty;
                    kitchenItems += `- ${item.qty}x ${product.name}\n`;
                    cashierItems += `- ${item.qty}x ${product.name} (@ ${formatRp(product.price)})\n`;
                }
            });

            const tax = subtotal * AppState.settings.taxRate;
            const totalFinal = subtotal + tax;
            const emailText = customerEmail ? customerEmail : "Tanpa Email Pelanggan";

            const kitchenPayload = { content: `🛎️ **PESANAN MASUK - MEJA ${AppState.currentTable}**\n${kitchenItems}--------------------------------------\n⏰ *Jam Order: ${timeNow}*\n📧 *Email:* ${emailText}` };
            const cashierPayload = { content: `💳 **TAGIHAN BARU - MEJA ${AppState.currentTable}**\n${cashierItems}--------------------------------------\nSubtotal: ${formatRp(subtotal)}\nPajak (${AppState.settings.taxRate * 100}%): ${formatRp(tax)}\n💰 **TOTAL TAGIHAN: ${formatRp(totalFinal)}**\n--------------------------------------\n📧 *Email:* ${emailText}\n⏰ *Status:* Antri Belum Bayar` };

            sendToDiscord('kitchen', kitchenPayload);
            sendToDiscord('cashier', cashierPayload);

            const newOrder = {
                id: 'ORD-' + Math.floor(Math.random() * 10000),
                table: AppState.currentTable,
                items: [...AppState.cart],
                total: totalFinal,
                time: timeNow,
                status: 'pending'
            };

            AppState.activeOrders.push(newOrder);

            const orderPayload = {
                order_id: newOrder.id,
                table_number: newOrder.table,
                total_amount: newOrder.total,
                order_time: newOrder.time,
                items: newOrder.items.map(item => {
                    const p = AppState.products.find(x => x.id === item.id);
                    return { id: item.id, name: p ? p.name : 'Menu', qty: item.qty, price: p ? p.price : 0 };
                })
            };
            syncToCloud('insert_order', orderPayload);

            SessionLocker.lock(AppState.currentTable);
            TableStatusManager.setStatus(AppState.currentTable, 'locked');

            SecuritySystem.updateLastTransaction();
            DatabaseManager.syncState();

            AppState.cart = [];
            showSuccessModal();
        }

