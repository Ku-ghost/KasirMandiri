                                    <span class="text-neon-blue font-mono font-bold">${formatRp(o.total)}</span>
                                </div>
                            `).join('')}
                        </div>
                    </div>
                </div>`;
        }

        /**
         * ==========================================
         * TAB PENGATURAN & SINKRONISASI BYOD LINK
         * ==========================================
         */
        function renderAdminSettings(container) {
            const baseDeploymentUrl = window.location.origin + window.location.pathname;
            const linkKasir = `${baseDeploymentUrl}?view=admin`;

            container.innerHTML = `
                <h2 class="text-2xl font-bold text-white mb-8">Pengaturan & Sinkronisasi Database</h2>
                <div class="max-w-2xl space-y-6 pb-20">
                    
                    <!-- PANEL TAUTAN OPERASIONAL BYOD -->
                    <div class="glass-panel p-6 rounded-2xl border border-neon-blue/30 bg-[#171310] relative overflow-hidden shadow-neon-blue">
                        <h3 class="text-lg font-bold text-white mb-2 flex items-center gap-2">
                            <i class="fas fa-link text-neon-blue"></i> Tautan Operasional Toko (BYOD Link)
                        </h3>
                        <p class="text-xs text-gray-400 mb-6 leading-relaxed">
                            Di bawah ini adalah tautan operasional toko Anda. Klik tombol "Salin" untuk membagikannya atau mengonversinya menjadi kode Barcode QR Code meja.
                        </p>
                        
                        <div class="space-y-4">
                            <div class="bg-black/40 border border-white/5 rounded-xl p-4">
                                <label class="block text-xs font-bold uppercase tracking-wider text-neon-purple mb-2">Tautan Web App Kasir Utama</label>
                                <div class="flex gap-2">
                                    <input type="text" id="link-kasir-input" readonly value="${linkKasir}" class="w-full bg-coffee-900 border border-white/10 rounded-lg px-3 py-2 text-xs font-mono text-gray-300 focus:outline-none">
                                    <button onclick="copyToClipboardFallback('link-kasir-input', 'Link Kasir')" class="px-4 py-2 bg-neon-purple text-white rounded-lg text-xs font-bold hover:shadow-neon-purple transition-all flex items-center gap-1">
                                        <i class="fas fa-copy"></i> Salin
                                    </button>
                                </div>
                            </div>

                            <div class="bg-black/40 border border-white/5 rounded-xl p-4">
                                <label class="block text-xs font-bold uppercase tracking-wider text-neon-blue mb-2">Generator Tautan Pemesanan Meja Pelanggan</label>
                                <div class="flex gap-4 items-center mb-3">
                                    <div class="flex-1">
                                        <span class="text-[10px] text-gray-500 uppercase font-semibold">Pilih Nomor Meja:</span>
                                        <select id="select-meja-gen" onchange="generateBYODLink()" class="w-full bg-coffee-900 border border-white/10 rounded-lg px-2 py-1.5 text-xs text-white focus:outline-none">
                                            ${Array.from({length: AppState.settings.numTables || 6}, (_, i) => `<option value="M-${i+1}">Meja M-${i+1}</option>`).join('')}
                                        </select>
                                    </div>
                                    <div class="flex-1">
                                        <span class="text-[10px] text-gray-500 uppercase font-semibold">Gembok Token BYOD:</span>
                                        <input type="text" id="byod-token-val" readonly value="byod_active" class="w-full bg-coffee-900/50 border border-white/10 rounded-lg px-2 py-1 text-xs text-center font-mono text-gray-500 cursor-not-allowed">
                                    </div>
                                </div>
                                <div class="flex gap-2">
                                    <input type="text" id="link-pelanggan-input" readonly value="" class="w-full bg-coffee-900 border border-white/10 rounded-lg px-3 py-2 text-xs font-mono text-gray-300 focus:outline-none">
                                    <button onclick="copyToClipboardFallback('link-pelanggan-input', 'Tautan Meja')" class="px-4 py-2 bg-neon-blue text-coffee-900 rounded-lg text-xs font-bold hover:shadow-neon-blue-hover transition-all flex items-center gap-1">
                                        <i class="fas fa-copy"></i> Salin
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- MANAJEMEN SLIDER PROMO ADVERTISING -->
                    <div class="glass-panel p-6 rounded-2xl border border-white/5">
                        <h3 class="text-lg font-bold text-white mb-2 flex items-center gap-2">
                            <i class="fas fa-images text-neon-blue"></i> Manajemen Banner Promo Kiosk
                        </h3>
                        <p class="text-xs text-gray-400 mb-4 leading-relaxed">
                            Tambahkan beberapa URL gambar/poster promo untuk ditampilkan sebagai slideshow interaktif di atas menu pesanan pelanggan.
                        </p>
                        
                        <div class="space-y-2 mb-4" id="promos-admin-list">
                            ${(AppState.settings.promos || []).map((url, i) => `
                                <div class="flex items-center gap-3 bg-black/40 border border-white/5 rounded-xl p-2 text-xs">
                                    <img src="${url}" class="w-12 h-8 object-cover rounded" onerror="this.src='https://images.unsplash.com/photo-1495474472287-4d71bcdd2085?auto=format&fit=crop&w=100&q=80'">
                                    <span class="flex-1 truncate font-mono text-gray-400 text-[10px]">${url}</span>
                                    <button onclick="removePromoLink(${i})" class="text-red-400 hover:text-red-300 px-2 py-1 transition-colors"><i class="fas fa-trash-can"></i></button>
                                </div>
                            `).join('')}
                            ${(AppState.settings.promos || []).length === 0 ? '<p class="text-xs text-gray-500 font-mono italic">Belum ada promo aktif. Slider di menu pesanan akan disembunyikan otomatis.</p>' : ''}
                        </div>
                        
                        <div class="flex gap-2">
                            <input type="text" id="new-promo-url" placeholder="https://domain.com/foto-promo.jpg" class="glow-input flex-1 bg-coffee-900 border border-white/10 rounded-xl px-3 py-2 text-xs text-white focus:outline-none">
                            <button onclick="addNewPromoLink()" class="px-4 py-2 bg-neon-blue text-coffee-900 rounded-xl text-xs font-bold hover:shadow-neon-blue transition-all">
                                Tambah
                            </button>
                        </div>
                    </div>

                    <!-- DINAMIS KUSTOMISASI TOKO -->
                    <div class="glass-panel p-6 rounded-2xl border border-white/5">
                        <h3 class="text-lg font-bold text-white mb-4 flex items-center gap-2"><i class="fas fa-store text-neon-blue"></i> Identitas Toko (Dinamis Kustom)</h3>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div>
                                <label class="block text-sm text-gray-400 mb-1">Nama Toko / Brand</label>
                                <input type="text" id="setting-store-name" value="${AppState.settings.storeName || ''}" class="glow-input w-full bg-coffee-900 border border-white/10 rounded-xl px-4 py-2 text-white focus:outline-none">
                            </div>
                            <div>
                                <label class="block text-sm text-gray-400 mb-1">Slogan Toko</label>
                                <input type="text" id="setting-store-slogan" value="${AppState.settings.storeSlogan || ''}" class="glow-input w-full bg-coffee-900 border border-white/10 rounded-xl px-4 py-2 text-white focus:outline-none">
                            </div>
                        </div>
                    </div>

                    <!-- D1 JSON SYNC & BACKUP BLOCK -->
                    <div class="glass-panel p-6 rounded-2xl border border-white/10">
                        <h3 class="text-lg font-bold text-white mb-2 flex items-center gap-2"><i class="fas fa-cloud-arrow-down text-neon-blue"></i> Cloudflare D1 & JSON Backup Sync</h3>
                        <p class="text-xs text-gray-400 mb-6 leading-relaxed bg-black/30 p-3 rounded-lg border border-white/5">PENTING: JSON bertindak sebagai file cadangan utama. Unduh data Anda secara berkala, simpan di Google Drive dengan akses "Editor/Public", lalu tempelkan tautan berbagi tersebut di bawah ini.</p>
                        
                        <div class="grid grid-cols-1 gap-4 mb-6">
                            <div>
                                <label class="block text-sm text-gray-400 mb-1">Google Drive JSON Master Link (Sinkronisasi D1)</label>
                                <input type="text" id="setting-drive-link" value="${AppState.settings.driveSyncLink || ''}" placeholder="https://drive.google.com/file/d/..." class="glow-input w-full bg-coffee-900 border border-white/10 rounded-xl px-4 py-3 text-white focus-border-neon-blue focus:outline-none text-sm">
                            </div>
                        </div>

                        <div class="flex flex-col md:flex-row gap-4 pt-4 border-t border-white/10 mb-4">
                            <button onclick="BackupManager.exportJSON()" class="flex-1 py-3 rounded-xl bg-neon-blue/15 text-neon-blue border border-neon-blue/30 hover:bg-neon-blue hover:text-coffee-900 font-bold transition-all flex items-center justify-center gap-2">
                                <i class="fas fa-download"></i> UNDUH MANUAL (.JSON)
                            </button>
                            <div class="flex-1 relative">
                                <input type="file" id="json-upload-input" accept=".json" class="hidden" onchange="BackupManager.importJSON(event)">
                                <button onclick="document.getElementById('json-upload-input').click()" class="w-full py-3 rounded-xl bg-coffee-800 text-gray-300 border border-white/10 hover:border-white hover:text-white font-bold transition-all flex items-center justify-center gap-2">
                                    <i class="fas fa-upload"></i> UPLOAD MANUAL (.JSON)
                                </button>
                            </div>
                        </div>

                        <div class="pt-4 border-t border-white/10">
                            <button onclick="closeStoreDay()" id="btn-close-store" class="w-full py-3 rounded-xl bg-gradient-to-r from-neon-purple to-neon-blue text-white font-bold shadow-neon-blue hover:shadow-neon-blue-hover transition-all flex items-center justify-center gap-2">
                                <i class="fas fa-shop-lock"></i> REKAP HARIAN (END OF DAY SYNC)
                            </button>
                        </div>
                    </div>

                    <!-- Webhook Settings -->
                    <div class="glass-panel p-6 rounded-2xl border border-white/5">
                        <h3 class="text-lg font-bold text-white mb-4 flex items-center gap-2"><i class="fab fa-discord text-neon-purple"></i> Discord Webhooks</h3>
                        <div class="space-y-4">
                            <div><label class="block text-sm text-gray-400 mb-1">Channel Dapur</label><input type="text" id="setting-wh-kitchen" value="${AppState.settings.webhookKitchen}" class="glow-input w-full bg-coffee-900 border border-white/10 rounded-xl px-4 py-2 text-white focus:outline-none font-mono text-sm"></div>
                            <div><label class="block text-sm text-gray-400 mb-1">Channel Kasir</label><input type="text" id="setting-wh-cashier" value="${AppState.settings.webhookCashier}" class="glow-input w-full bg-coffee-900 border border-white/10 rounded-xl px-4 py-2 text-white focus:outline-none font-mono text-sm"></div>
                        </div>
                    </div>

                    <!-- General Settings -->
                    <div class="glass-panel p-6 rounded-2xl border border-white/5">
                        <h3 class="text-lg font-bold text-white mb-4"><i class="fas fa-store text-gray-400"></i> Operasional</h3>
                        <div class="grid grid-cols-2 gap-4">
                            <div><label class="block text-sm text-gray-400 mb-1">Pajak PB1 (%)</label><input type="number" id="setting-tax" value="${AppState.settings.taxRate * 100}" class="glow-input w-full bg-coffee-900 border border-white/10 rounded-xl px-4 py-2 text-white focus:outline-none"></div>
                            <div><label class="block text-sm text-gray-400 mb-1">Jumlah Meja</label><input type="number" id="setting-tables" value="${AppState.settings.numTables}" class="glow-input w-full bg-coffee-900 border border-white/10 rounded-xl px-4 py-2 text-white focus:outline-none"></div>
                        </div>
                    </div>

                    <div class="flex justify-end">
                        <button onclick="saveSettings()" class="bg-neon-blue text-coffee-900 px-8 py-3 rounded-xl font-bold shadow-neon-blue hover:shadow-neon-blue-hover transition-all">Simpan Pengaturan</button>
                    </div>
                </div>
            `;

            window.addNewPromoLink = () => {
                const input = document.getElementById('new-promo-url');
                const url = input.value.trim();
                if (!url) return showCustomToast("Tautan promo tidak boleh kosong!", "error");
                if (!url.startsWith('http://') && !url.startsWith('https://')) {
                    return showCustomToast("Tautan harus dimulai dengan http:// atau https://", "error");
                }
                if (!AppState.settings.promos) AppState.settings.promos = [];
                AppState.settings.promos.push(url);
                DatabaseManager.syncState();
                showCustomToast("Promo berhasil ditambahkan!");
                renderAdminSettings(container);
            };

            window.removePromoLink = (index) => {
                if (!AppState.settings.promos) return;
                AppState.settings.promos.splice(index, 1);
                DatabaseManager.syncState();
                showCustomToast("Promo berhasil dihapus!");
                renderAdminSettings(container);
            };

            window.generateBYODLink = () => {
                const selectMeja = document.getElementById('select-meja-gen').value;
                const finalBYODLink = `${baseDeploymentUrl}?table=${selectMeja}`;
                const inputEl = document.getElementById('link-pelanggan-input');
                if (inputEl) {
                    inputEl.value = finalBYODLink;
                }
            };

            window.generateBYODLink();

            window.copyToClipboardFallback = (inputId, itemType) => {
                const copyText = document.getElementById(inputId);
                copyText.select();
                copyText.setSelectionRange(0, 99999); 
                document.execCommand('copy');
                showCustomToast(`${itemType} berhasil disalin ke clipboard!`);
            };

            window.saveSettings = () => {
                AppState.settings.storeName = document.getElementById('setting-store-name').value || 'Cyber Brew';
                AppState.settings.storeSlogan = document.getElementById('setting-store-slogan').value || 'Smart Kiosk & POS Mandiri';
                AppState.settings.webhookKitchen = document.getElementById('setting-wh-kitchen').value;
                AppState.settings.webhookCashier = document.getElementById('setting-wh-cashier').value;
                AppState.settings.driveSyncLink = document.getElementById('setting-drive-link').value;
                AppState.settings.taxRate = parseFloat(document.getElementById('setting-tax').value) / 100;
                AppState.settings.numTables = parseInt(document.getElementById('setting-tables').value);
                
                DatabaseManager.syncState();
                showCustomToast('Pengaturan berhasil disimpan!');
                setTimeout(() => navigateTo('admin'), 1000);
            };

            window.closeStoreDay = async () => {
                showCustomConfirm(
                    "Konfirmasi Tutup Toko", 
                    "Apakah Anda yakin ingin melakukan Tutup Toko? Semua data transaksi harian akan dikompresi menjadi JSON, dikirim ke Discord, dan disinkronkan ke Cloud D1.", 
                    async () => {
                        const btn = document.getElementById('btn-close-store');
                        if (btn) {
                            btn.disabled = true;
                            btn.innerText = "Memproses Rekap & Backup...";
                        }

                        const res = await syncToCloud('close_store', {});
                        if (res && res.success) {
                            showCustomToast("Tutup toko sukses! Rekap harian telah disinkronisasikan.");
                            AppState.activeOrders = [];
                            DatabaseManager.syncState();
                            setTimeout(() => renderAdminDashboard(), 1000);
                        } else {
                            showCustomToast("Gagal Tutup Toko. Hubungkan koneksi internet.", "error");
                            if (btn) {
                                btn.disabled = false;
                                btn.innerText = "TUTUP TOKO (END OF DAY SYNC)";
                            }
                        }
                    }
                );
            };
        }

        /**
         * ==========================================
         * 12. BOOTSTRAP INISIALISASI (LIFECYCLE)
         * ==========================================
         */
        window.onload = async () => {
            const isSecure = await SecuritySystem.lifecycleCheck();
            if (isSecure) {
                initRouter();
            }
        };

    </script>
</body>
</html>
