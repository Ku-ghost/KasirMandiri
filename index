         * 6. ROUTING & URL PARAMETER PARSING
         * ==========================================
         */
        function initRouter() {
            const params = new URLSearchParams(window.location.search);
            if (params.has('view') && params.get('view') === 'admin') {
                navigateTo('admin');
            } else if (params.has('table')) {
                navigateTo('table', params.get('table'));
            } else {
                navigateTo('landing');
            }
        }

        function navigateTo(mode, payload) {
            try {
                if (mode === 'admin') {
                    AppState.viewMode = 'admin';
                    history.pushState(null, '', '?view=admin');
                    renderAdminLogin();
                } else if (mode === 'table') {
                    AppState.viewMode = 'customer';
                    AppState.currentTable = payload;
                    history.pushState(null, '', '?table=' + payload);
                    
                    if (AppState.settings.storeStatus === 'closed') {
                        renderStoreClosedScreen();
                        return;
                    }

                    if (TableStatusManager.getStatus(payload) === 'vacant') {
                        TableStatusManager.setStatus(payload, 'ordering');
                    }
                    
                    if (SessionLocker.isLocked(payload)) {
                        renderLockedBYODScreen(payload);
                    } else {
                        renderCustomerKiosk();
                    }
                } else {
                    AppState.viewMode = 'landing';
                    history.pushState(null, '', window.location.pathname || '/');
                    renderLandingPage();
                }
            } catch (e) {
                if (mode === 'admin') { AppState.viewMode = 'admin'; renderAdminLogin(); }
                else if (mode === 'table') { AppState.viewMode = 'customer'; AppState.currentTable = payload; renderCustomerKiosk(); }
                else { AppState.viewMode = 'landing'; renderLandingPage(); }
            }
        }

